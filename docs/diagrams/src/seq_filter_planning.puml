@startuml
!theme pfe from .

actor "Utilisateur" as User
boundary "Interface Planning" as Front
control "Controller" as Controller
entity "Planning Service" as Service
database "Base de données" as DB

User -> Front : Saisit filtres (Date, Salle, Enseignant)
Front -> Controller : GET /api/planning?date=...&salle=...
activate Controller

Controller -> Service : rechercherPlanning(criteres)
activate Service

Service -> DB : Requête dynamique (Criteria API/Specification)
activate DB
DB --> Service : Liste des soutenances filtrées
deactivate DB

Service --> Controller : Résultats
deactivate Service

Controller --> Front : 200 OK (List JSON)
Front --> User : Mettre à jour l'affichage
deactivate Controller

@enduml
