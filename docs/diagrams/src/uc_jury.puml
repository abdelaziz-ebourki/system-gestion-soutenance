@startuml
!include style.puml
left to right direction

actor "Enseignant / Membre de jury" as Jury

rectangle "Module Jury" {
    usecase "Consulter planning" as UC1
    usecase "Consulter convocation" as UC2
    usecase "Déclarer indisponibilité" as UC3
    usecase "Saisir évaluation" as UC4
    usecase "Générer fiches d'évaluation" as UC5

    usecase "Valider / modifier évaluation" as UC6
    usecase "Consulter informations étudiant" as UC7
}

Jury --> UC1
Jury --> UC2
Jury --> UC3
Jury --> UC4
Jury --> UC5

UC6 ..> UC4 : <<extend>>
UC4 ..> UC7 : <<include>>
@enduml
