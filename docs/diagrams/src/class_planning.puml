@startuml
!theme pfe from .

enum SoutenanceStatus {
    CREEE
    PLANIFIEE
    JURY_AFFECTE
    CONVOQUEE
    EN_COURS
    TERMINEE
    EVALUEE
    CLOTUREE
    ANNULEE
}

enum DecisionEnum {
    ADMIS
    ADMIS_AVEC_CORRECTIONS
    AJOURNE
}

class Soutenance {
    + int id
    + date datePassage
    + time heureDebut
    + int dureeMinutes
    + SoutenanceStatus statut
    + planifier()
    + annuler()
}

class Salle {
    + int id
    + string nom
    + string batiment
    + int capacite
    + boolean disponible
    + verifierDisponibilite()
}

class MembreJury {
    + JuryRole roleJury
    + boolean present
}

class Evaluation {
    + int id
    + float note
    + string observations
    + DecisionEnum decision
    + boolean validee
}

class PlanningSession {
    + int id
    + string libelle
    + date dateDebut
    + date dateFin
    + SoutenanceStatus statut
}

class Convocation {
    + int id
    + string type
    + boolean envoyee
    + generer()
}

PlanningSession "1" *-- "*" Soutenance : contient
Soutenance "*" -- "1" Salle : se déroule dans
Soutenance "1" -- "3..*" MembreJury : composée de
Soutenance "1" -- "1" Evaluation : possède
Soutenance "1" -- "1..*" Convocation : génère

@enduml
