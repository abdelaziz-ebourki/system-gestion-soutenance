@startuml
!theme pfe from .

actor "Utilisateur" as User
boundary "Page Login" as Front
control "Controller" as Controller
entity "Auth Service" as Service
entity "Email Service" as Mail
database "Base de données" as DB

User -> Front : Clique sur "Mot de passe oublié"
Front -> Controller : POST /api/auth/reset-password-request (email)
activate Controller

Controller -> Service : genererResetToken(email)
activate Service

Service -> DB : Vérifier email
activate DB
DB --> Service : Utilisateur trouvé
deactivate DB

Service -> Service : Créer Token UUID sécurisé
Service -> DB : Enregistrer Token (Expiration 24h)
activate DB
DB --> Service : OK
deactivate DB

Service -> Mail : envoyerLienReset(email, token)
activate Mail
Mail -> Mail : Envoi SMTP
Mail --> Service : Mail envoyé
deactivate Mail

Service --> Controller : Demande traitée
deactivate Service

Controller --> Front : 200 OK
deactivate Controller

Front --> User : "Consultez vos e-mails"

@enduml
