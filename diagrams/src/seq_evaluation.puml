@startuml
!theme pfe from .

actor "Membre Jury" as Jury
boundary "Interface Évaluation" as Front
control "Controller" as Controller
entity "Evaluation Service" as Service
database "Base de données" as DB

Jury -> Front : Saisit note et observations
Front -> Controller : POST /api/evaluations (note, observations, idSoutenance)
activate Controller

Controller -> Service : enregistrerEvaluation(data)
activate Service

Service -> DB : Sauvegarder note individuelle du membre
activate DB
DB --> Service : OK
deactivate DB

Service -> Service : Recalculer moyenne provisoire (RG6)
Service -> DB : Mettre à jour résultat final si toutes les notes sont validées
activate DB
DB --> Service : OK
deactivate DB

Service --> Controller : Évaluation enregistrée
deactivate Service

Controller --> Front : 201 Created
deactivate Controller

Front --> Jury : Afficher récapitulatif et succès

@enduml
